{
  "openapi": "3.0.0",
  "info": {
    "title": "Bookshell API",
    "version": "1.0.0",
    "description": "API de usuarios, libros y reviews"
  },
  "servers": [
    {
      "url": "http://localhost:8080/api"
    }
  ],

  "paths": {

    "/register": {
      "post": {
        "summary": "Registrar usuario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Usuario registrado" }
        }
      }
    },

    "/login": {
      "post": {
        "summary": "Login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Token generado" }
        }
      }
    },

    "/logout": {
      "post": {
        "summary": "Logout",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Logout correcto" }
        }
      }
    },

    "/usuarios": {
      "get": {
        "summary": "Listar usuarios",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UsuariosResponse" }
              }
            }
          }
        }
      }
    },

    "/usuarios/{id}": {
      "get": {
        "summary": "Obtener usuario",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Usuario" }
              }
            }
          }
        }
      }
    },

    "/usuarios/buscar/{name}": {
      "get": {
        "summary": "Buscar usuario",
        "parameters": [
          { "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Resultados" } }
      }
    },

    "/users/{id}": {
      "put": {
        "summary": "Actualizar usuario",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserUpdateInput" }
            }
          }
        },
        "responses": { "200": { "description": "Actualizado" } }
      },
      "delete": {
        "summary": "Eliminar usuario",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Eliminado" } }
      }
    },

    "/libros": {
      "get": {
        "summary": "Listar libros",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LibrosResponse" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Crear libro",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LibroInput" }
            }
          }
        },
        "responses": { "200": { "description": "Creado" } }
      }
    },

    "/libros/{id}": {
      "get": {
        "summary": "Obtener libro",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Libro encontrado" } }
      },
      "put": {
        "summary": "Actualizar libro",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LibroInput" }
            }
          }
        },
        "responses": { "200": { "description": "Actualizado" } }
      },
      "delete": {
        "summary": "Eliminar libro",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Eliminado" } }
      }
    },

    "/reviews": {
      "get": {
        "summary": "Listar reviews",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReviewsResponse" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Crear review",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ReviewInput" }
            }
          }
        },
        "responses": { "200": { "description": "Creado" } }
      }
    }

  },

  "components": {

    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },

    "schemas": {

      "RegisterInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "password": { "type": "string" }
        }
      },

      "LoginInput": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        }
      },

      "UserUpdateInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" }
        }
      },

      "LibroInput": {
        "type": "object",
        "properties": {
          "titulo": { "type": "string" },
          "autor": { "type": "string" },
          "genero": { "type": "string" },
          "descripcion": { "type": "string" }
        }
      },

      "ReviewInput": {
        "type": "object",
        "properties": {
          "libro_id": { "type": "integer" },
          "valoracion": { "type": "integer" },
          "comentario": { "type": "string" }
        }
      },

      "Usuario": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "roll": { "type": "string" }
        }
      },

      "Libro": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "titulo": { "type": "string" },
          "autor": { "type": "string" },
          "genero": { "type": "string" },
          "descripcion": { "type": "string" }
        }
      },

      "Review": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "comentario": { "type": "string" },
          "valoracion": { "type": "integer" },
          "libro_id": { "type": "integer" },
          "user_id": { "type": "integer" }
        }
      },

      "UsuariosResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Usuario" }
          }
        }
      },

      "LibrosResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Libro" }
          }
        }
      },

      "ReviewsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Review" }
          }
        }
      }

    }
  }
}